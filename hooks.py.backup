# DCIM PLUS - Custom UI/UX
# =====================================================

app_include_css = [
    "css/dcim_custom.css"
]

app_include_js = [
    "js/dcim_custom.js"
]

# Add CSS and JS to every page
def add_css_to_pages():
    from frappe import hooks
    hooks.app_include_css = "dcim_custom.css"
    hooks.app_include_js = "dcim_custom.js"

